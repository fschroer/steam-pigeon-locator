# Included by the CubeIDE-generated makefiles -- both Debug/ and Release/ end
# with `-include ../makefile.targets`.  Paths here are relative to that build
# dir, which is why they are written as ../ back to the project root.  Living
# outside those dirs is the point: Debug/ and Release/ are gitignored and get
# regenerated by the IDE, so an edit made in there would be untracked and lost.
#
# Those makefiles run Scripts/GenVersion.sh only from their `pre-build` target.
# `make main-build`, or building a single object, skips pre-build entirely and
# silently compiles whatever version.h happens to be on disk -- which is how a
# 07-14 stamp ended up inside a 07-18 Locator.elf.  Making version.h a real
# prerequisite of the one object that includes it closes the hole no matter
# which target is invoked.
#
# GenVersion.sh rewrites version.h only when the stamp actually changes, so the
# phony prerequisite below re-runs the script every build without forcing a
# recompile and relink each time.

BASH ?= "C:/Program Files/Git/bin/bash.exe"

VERSION_HEADER := ../Core/Inc/version.h

.PHONY: force-version
force-version:

$(VERSION_HEADER): force-version
	$(BASH) "../Scripts/GenVersion.sh"

Rocket/Communication/Src/Communication.o: $(VERSION_HEADER)
